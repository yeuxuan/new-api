# 本地调试前端时，把后端 API 指到已部署的服务器
# 复制此文件为 .env.development 并填入你的后端地址，例如：
# cp .env.development.example .env.development

# VITE_ 前缀的变量会暴露给浏览器，axios 会用完整 URL 直接请求导致跨域
# 所以此处留空，让 axios 使用相对路径，由 Vite 代理转发
VITE_REACT_APP_SERVER_URL=

# 仅 Vite/Node 构建侧读取，不暴露给浏览器，用于代理转发目标
# 例如: https://api.example.com  或  http://192.168.1.100:3000
API_SERVER_URL=
